<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.powerreliability.index.mapper.ReliabilityIndexMapper">

    <!-- 通用结果映射 -->
    <resultMap id="BaseResultMap" type="com.powerreliability.index.entity.ReliabilityIndex">
        <id column="id" property="id"/>
        <result column="stat_type" property="statType"/>
        <result column="target_id" property="targetId"/>
        <result column="period" property="period"/>
        <result column="stat_date" property="statDate"/>
        <result column="asai" property="asai"/>
        <result column="asidi" property="asidi"/>
        <result column="saifi" property="saifi"/>
        <result column="saidi" property="saidi"/>
        <result column="caidi" property="caidi"/>
        <result column="ens" property="ens"/>
        <result column="aens" property="aens"/>
    </resultMap>

    <!-- 查询字段 -->
    <sql id="BaseColumns">
        id, stat_type, target_id, period, stat_date,
        asai, asidi, saifi, saidi, caidi, ens, aens
    </sql>

    <!-- 按日期范围查询指标数据 -->
    <select id="selectByDateRange" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM reliability_index
        WHERE stat_date &gt;= #{startDate}
          AND stat_date &lt;= #{endDate}
        ORDER BY stat_date ASC, period ASC
    </select>

    <!-- 按统计类型、日期范围和周期查询 -->
    <select id="selectByStatTypeAndDateRange" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM reliability_index
        WHERE stat_type = #{statType}
          AND stat_date &gt;= #{startDate}
          AND stat_date &lt;= #{endDate}
          <if test="period != null">
              AND period = #{period}
          </if>
        ORDER BY stat_date ASC
    </select>

</mapper>
